# Pinned Splice/Canton image version
IMAGE_TAG=0.5.10

# Registry
SPLICE_REGISTRY=europe-docker.pkg.dev/da-images/public

# Auth mode: oauth2 or shared-secret
AUTH_MODE=oauth2

# Port prefixes: 2=AppUser, 3=AppProvider, 4=SV
# Suffixes: 901=LedgerAPI, 902=AdminAPI, 903=ValidatorAPI, 975=JSONAPI
APP_USER_UI_PORT=2000
APP_PROVIDER_UI_PORT=3000
SV_UI_PORT=4000

# Keycloak
KEYCLOAK_PORT=8082

# PostgreSQL
DB_PORT=5432
DB_USER=cnadmin
DB_PASSWORD=supersafe

# Resource limits (increase if you have RAM to spare)
CANTON_MEMORY_LIMIT=3g
SPLICE_MEMORY_LIMIT=2g
POSTGRES_MEMORY_LIMIT=1g
KEYCLOAK_MEMORY_LIMIT=512m
NGINX_MEMORY_LIMIT=128m
