# canton-devrel configuration
# Pinned Splice version — update this to upgrade the stack
IMAGE_TAG=0.5.10

# Derived tarball name and download URL
SPLICE_TARBALL=${IMAGE_TAG}_splice-node.tar.gz
SPLICE_DOWNLOAD_URL=https://github.com/hyperledger-labs/splice/releases/download/v${IMAGE_TAG}/${IMAGE_TAG}_splice-node.tar.gz

# Where canton-devrel caches the extracted bundle
BUNDLE_DIR=$HOME/.canton-devrel/bundle